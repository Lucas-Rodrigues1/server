					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"}",
									"if (jsonData.user && jsonData.user.id) {",
									"    pm.collectionVariables.set('userId', jsonData.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"lucasRodrigues\",\n  \"password\": \"M@ndateste65\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Autentica o usuario e retorna um token JWT. O token e o userId sao salvos automaticamente nas variaveis da colecao para uso nas proximas requisicoes."
					},
					"response": [
						{
							"name": "200 - Login bem-sucedido",
							"status": "OK",
							"code": 200,
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n  \"success\": true,\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": \"69b5b2b45066945dadbb638e\",\n    \"username\": \"lucasRodrigues\",\n    \"name\": \"Lucas Eduardo\"\n  }\n}"
						},
