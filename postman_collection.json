				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"}",
									"if (jsonData.user && jsonData.user.id) {",
									"    pm.collectionVariables.set('userId', jsonData.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"lucas_eduardo\",\n  \"password\": \"M@ndateste65\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Autentica o usuário e retorna um token JWT. O token e o userId são salvos automaticamente nas variáveis da coleção para uso nas próximas requisições."
					},
					"response": [
						{
							"name": "200 - Login bem-sucedido",
							"status": "OK",
							"code": 200,
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n  \"success\": true,\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": \"69b587138cc75dd0bdb8ba6c\",\n    \"username\": \"lucas_eduardo\",\n    \"name\": \"Lucas Eduardo\"\n  }\n}"
						},
						{
							"name": "401 - Credenciais inválidas",
							"status": "Unauthorized",
							"code": 401,
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n  \"success\": false,\n  \"message\": \"Authentication failed\"\n}"
						}
					]
				},
